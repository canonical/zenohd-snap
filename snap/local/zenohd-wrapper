#!/bin/sh
# Launch zenohd, automatically picking up a user-provided config if present.
# The following filenames are probed in order under /var/snap/zenohd/common/:
#   config.json5, config.yaml, config.yml
#
# Any explicit -c / --config argument (in any form) takes precedence and
# suppresses the auto-injection.

# Check if the user already passed -c or --config in any clap form:
#   -c <path>, --config <path>, --config=<path>, -c=<path>, -c<path>
has_config=0
for arg in "$@"; do
    case "$arg" in
        -c|--config|--config=*|-c?*) has_config=1; break ;;
    esac
done

config=""
if [ "$has_config" -eq 0 ]; then
    for candidate in \
        "$SNAP_COMMON/config.json5" \
        "$SNAP_COMMON/config.yaml" \
        "$SNAP_COMMON/config.yml"
    do
        if [ -f "$candidate" ]; then
            config="$candidate"
            break
        fi
    done
fi

if [ -n "$config" ]; then
    exec "$SNAP/bin/zenohd" \
        --plugin-search-dir "$SNAP/lib/zenoh/plugins" \
        --plugin-search-dir "$SNAP_COMMON/plugins" \
        -c "$config" "$@"
else
    exec "$SNAP/bin/zenohd" \
        --plugin-search-dir "$SNAP/lib/zenoh/plugins" \
        --plugin-search-dir "$SNAP_COMMON/plugins" \
        "$@"
fi
